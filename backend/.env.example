# Copy to .env and fill in. The intake service runs without any of these
# (OSV.dev is unauthenticated); they are here for downstream stages.

# OSV.dev REST API base (override only for testing/mocking)
OSV_API_BASE=https://api.osv.dev

# Comma-separated origins allowed to call the API (the Vite dashboard)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# HTTP timeout (seconds) for outbound OSV calls
HTTP_TIMEOUT=15
