# supplyfix configuration (optional).
# Copy to config.yaml to override defaults. All values are optional.
#
# The only required secret is the ANTHROPIC_API_KEY environment variable:
#   export ANTHROPIC_API_KEY=sk-ant-...
#
# Models can also be overridden via env vars:
#   SUPPLYFIX_SUMMARY_MODEL, SUPPLYFIX_PACKAGE_MODEL, SUPPLYFIX_VULN_MODEL

app_settings:
  models:
    # Coordination tiers use Sonnet; the code-editing tier uses Opus.
    summary: claude-sonnet-4-6
    package: claude-sonnet-4-6
    vulnerability: claude-opus-4-8

  budget:
    # Maximum model requests per agent run (guards against runaway loops).
    max_summary_requests: 25
    max_package_requests: 15
    max_vulnerability_requests: 30
