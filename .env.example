# PatchPilot — Azure OpenAI credentials
# Copy to .env (which is gitignored) and fill in real values. Never commit .env.

# Primary key from the Azure OpenAI resource (Keys and Endpoint blade).
API_KEY=

# Azure OpenAI / Foundry project endpoint, e.g.
# https://patchpilot-openai.openai.azure.com/
PROJECT_ENDPOINT=

# Azure region the resource is deployed in, e.g. eastus2
REGION=westus

# --- Canonical Azure OpenAI vars (used by the agents) -----------------------
# The agents read AZURE_OPENAI_* first, falling back to API_KEY/PROJECT_ENDPOINT
# above — so you can fill in either set.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# "v1" = modern Azure OpenAI v1 API (recommended; required by Foundry resources).
# Use a dated version (e.g. 2024-10-21) only for a classic Azure OpenAI resource.
AZURE_OPENAI_API_VERSION=v1
# Your Azure *deployment name* (what you named the model when you deployed it).
# One var sets all three agent tiers — set this if you have a single deployment.
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Email notification (optional) ------------------------------------------
# Leave PATCHPILOT_SMTP_HOST unset to only record emails to ./outbox/.
PATCHPILOT_SMTP_HOST=
PATCHPILOT_SMTP_PORT=587
PATCHPILOT_SMTP_USER=
PATCHPILOT_SMTP_PASSWORD=

# --- Backend ----------------------------------------------------------------
# Comma-separated origins allowed to call the API (the Vite dashboard).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
