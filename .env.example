# PatchPilot — Azure OpenAI credentials
# Copy to .env (which is gitignored) and fill in real values. Never commit .env.

# Primary key from the Azure OpenAI resource (Keys and Endpoint blade).
API_KEY=

# Azure OpenAI / Foundry project endpoint, e.g.
# https://patchpilot-openai.openai.azure.com/
PROJECT_ENDPOINT=

# Azure region the resource is deployed in, e.g. eastus2
REGION=
